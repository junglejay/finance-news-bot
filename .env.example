# Core runtime
TIMEZONE=Asia/Shanghai

# OpenAI-compatible AI gateway
AI_API_KEY=
AI_BASE_URL=https://minitoken.top/v1
AI_MODEL=deepseek-v4-flash

# Optional DingTalk custom robot. Leave DINGTALK_WEBHOOK blank to print the brief.
# Set DINGTALK_SECRET only when the robot's security mode is “signed”.
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# Optional Financial Times authorised feed. Leave blank to disable FT.
FT_FEED_URL=
# Optional Financial Times official newsletter sender in the IMAP mailbox below.
FT_EMAIL_SENDER=

# Google Scholar Alert mailbox. Leave SCHOLAR_IMAP_HOST blank to disable it.
SCHOLAR_IMAP_HOST=
SCHOLAR_IMAP_PORT=993
SCHOLAR_IMAP_USERNAME=
SCHOLAR_IMAP_PASSWORD=
SCHOLAR_IMAP_FOLDER=INBOX
SCHOLAR_SENDER=scholaralerts-noreply@google.com

# SEC asks automated clients to identify themselves with contact information.
SEC_USER_AGENT=commodity-risk-intel-bot/1.0 contact=you@example.com
